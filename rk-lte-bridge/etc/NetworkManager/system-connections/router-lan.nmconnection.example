# Copy to /etc/NetworkManager/system-connections/router-lan.nmconnection
# (drop the .example suffix), chmod 0600 root:root, then
# `nmcli connection reload`. NetworkManager will fill in a fresh UUID.
# Autoconnect starts off; router-activate flips it on.

[connection]
id=router-lan
type=ethernet
interface-name=eth0
autoconnect=false

[ethernet]

[ipv4]
address1=192.168.50.1/24
method=manual
never-default=true

[ipv6]
addr-gen-mode=default
method=ignore

[proxy]
